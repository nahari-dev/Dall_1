# =============================================================================
# Dall Academy — Environment Configuration
# =============================================================================

# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=

# Model in "provider:model" format.  Switching providers is a single-line change.
# Examples:
#   anthropic:claude-sonnet-4-20250514   (default)
#   openai:gpt-4o
#   google-genai:gemini-2.0-flash
LLM_MODEL=anthropic:claude-sonnet-4-20250514

# Embedding model (used for RAG vector search)
EMBEDDING_MODEL=text-embedding-3-small

# --- Database ---
DATABASE_URL=postgresql+asyncpg://dall_user:dall_password@localhost:5432/dall_academy
DATABASE_SYNC_URL=postgresql://dall_user:dall_password@localhost:5432/dall_academy
POSTGRES_USER=dall_user
POSTGRES_PASSWORD=dall_password
POSTGRES_DB=dall_academy

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=dental_knowledge

# --- JWT Auth ---
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption (Saudi PDPL compliance) ---
PII_ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key

# --- S3-Compatible Storage ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=dall-academy

# --- Application ---
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_LEVEL=INFO

# --- Rate Limiting (queries per day by tier) ---
RATE_LIMIT_FREE=5
RATE_LIMIT_PRO=49
RATE_LIMIT_ELITE=0

# --- Exam Configuration ---
SDLE_PASS_SCORE=70
DEFAULT_QUIZ_TIME_PER_QUESTION=90
